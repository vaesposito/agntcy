# Anthropic — required to run real agent calls (milestone 4+)
# ANTHROPIC_API_KEY=
# Alternately, specify an auth token. One of the API_KEY or AUTH_TOKEN is required.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://llm-proxy.prod.outshift.ai

# Source connectors. Specify Oauth2 credentials for any you want to use.
CONFLUENCE_CLIENT_ID=KW10oZsb59RJBnTsj2D14sxMThYKoM0O
CONFLUENCE_CLIENT_SECRET=
CONFLUENCE_REDIRECT_URI=http://localhost:3001/oauth/confluence/callback

# Webex personal access token (~12h lifetime). Required only for milestone 7.
# NEVER commit this. NEVER paste into chat.
WEBEX_CLIENT_ID=Cfc1a9f01289f8e16eefd3cd1ecabf8a96f2fdbbc7f62c726efaf9e12ca96ad00
WEBEX_CLIENT_SECRET=
WEBEX_REDIRECT_URI=http://localhost:3001/oauth/webex/callback
# WEBEX_TOKEN=

GITHUB_CLIENT_ID=Iv23liNCDywTsOb0TJBA
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/oauth/github/callback
# GITHUB_TOKEN=

# Paths (defaults are fine for local dev)
TTT_DB_PATH=./data/ttt.db
TTT_REPORT_REPO=./data/reports.git
TTT_REPORT_WORKTREE=./data/reports-wc

# Database — SQLite by default. Set TTT_DATABASE_URL to use PostgreSQL.
# TTT_POSTGRES_DB=ttt
# TTT_DATABASE_URL=postgresql+asyncpg://ttt:ttt@localhost:5432/ttt

# Local user
TTT_DEV_USER_EMAIL=dev@local
TTT_DEV_USER_NAME=Dev User
# TTT_PROJECT_CREATOR_ROLE=admin  # role assigned to creator on new project (viewer|editor|admin)
# LOG_LEVEL=INFO  # log level for ttt.* loggers (DEBUG|INFO|WARNING|ERROR|CRITICAL)